<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{projectTitle}} - Project Showcase</title>
</head>
<body>
  <main>
    <h1>{{projectTitle}}</h1>
    <p>{{oneLineValue}}</p>
    <section>
      <h2>Project Title + One-Line Value Proposition</h2>
      {{hero}}
    </section>
    <section>
      <h2>Problem / User Pain Point</h2>
      {{problem}}
    </section>
    <section>
      <h2>Context & Constraints</h2>
      {{context}}
    </section>
    <section>
      <h2>My Role and Contribution Boundary</h2>
      {{role}}
    </section>
    <section>
      <h2>Architecture Overview</h2>
      {{architecture}}
    </section>
    <section>
      <h2>Evidence-Backed Technical Claims</h2>
      {{claims}}
    </section>
    <section>
      <h2>Key Decisions & Trade-Offs</h2>
      {{decisions}}
    </section>
    <section>
      <h2>Validation / Tests / Metrics / Demo Evidence</h2>
      {{validation}}
    </section>
    <section>
      <h2>Timeline / Milestones</h2>
      {{timeline}}
    </section>
    <section>
      <h2>What I Would Improve Next</h2>
      {{improvements}}
    </section>
    <section>
      <h2>Public-Safe Evidence Appendix</h2>
      {{appendix}}
    </section>
    <section>
      <h2>Links</h2>
      {{links}}
    </section>
  </main>
</body>
</html>
